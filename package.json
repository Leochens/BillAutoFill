{
  "name": "bill-autofill",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Chrome extension for fictional test billing profiles and safe form autofill.",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "autofill",
    "test-data",
    "qa"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "package": "rm -f bill-autofill-v*.zip && npm run build && VERSION=$(node -p \"require('./package.json').version\") && cd dist && zip -qr ../bill-autofill-v$VERSION.zip .",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "jsdom": "^25.0.1",
    "vitest": "^4.1.6"
  }
}
